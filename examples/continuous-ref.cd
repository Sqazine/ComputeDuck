a=[1,2,3,4,5];

b=ref a;

c=ref b[1];

c=10000;

println(a);#[1,10000,3,4,5];
println(c);#10000

d=ref c;

d=100;

println(a);#[1,100,3,4,5];
println(c);#100

# repeat ref
a = {
    x:0,
    y:0
};

b = ref a;
b.x = 100;

println(a); # {x:100,y:0}

a = 10;
b = ref a;
b = 20;
println(a); # 20

# array ref
a = 10;
array = [1,ref a,10];
array[1] = 1000;
println(a);# 1000

a = 20;
array = [1,ref a,10];
array[1] = 10000;
println(a);# 10000
